<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | Bader Alsabah</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@700&family=Inter:wght@300;400;600;700&display=swap"
      rel="stylesheet">
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        background: #f5f7fa;
        font-family: 'Inter', sans-serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      body > main,
      body > div,
      body > section {
        flex: 1;
      }
      nav {
        background: #0a1a3a;
        padding: 1.2rem 3rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      nav .brand {
        font-family: 'Orbitron', monospace;
        color: #ffffff;
        font-size: 1rem;
        font-weight: 700;
        text-decoration: none;
        letter-spacing: 0.08em;
      }
      nav .links {
        display: flex;
        gap: 2.5rem;
      }
      nav .links a {
        font-size: 0.82rem;
        letter-spacing: 0.08em;
        color: #8aaad0;
        text-decoration: none;
        text-transform: uppercase;
        font-weight: 600;
      }
      footer {
        background: #0a1a3a;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        padding: 1.5rem 3rem;
        text-align: center;
        font-family: 'Share Tech Mono', monospace;
        font-size: 0.72rem;
        color: #4a6a8a;
        letter-spacing: 0.15em;
      }
      .nav-toggle {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.2rem;
      }
      .nav-toggle span {
        display: block;
        width: 22px;
        height: 2px;
        background: #ffffff;
      }
      @media(max-width: 768px) {
        nav {
          flex-wrap: wrap;
          padding: 1rem 1.5rem;
        }
        .nav-toggle {
          display: flex;
        }
        nav .links,
        .links {
          display: none !important;
          width: 100%;
          flex-direction: column;
          gap: 0;
          padding: 0.5rem 0;
        }
        .links.open {
          display: flex !important;
        }
        .links a {
          padding: 0.75rem 0;
          border-top: 1px solid rgba(255, 255, 255, 0.06);
        }
      }
    </style>
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-3XTE99YZ8N"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-3XTE99YZ8N');
    </script>
    <!-- Open Graph -->
    <meta property="og:title" content="{{ title }} | badercodes.com">
    <meta property="og:description" content="{{ description if description else 'Computer Engineer and Cybersecurity enthusiast writing about CTFs, blue team labs, and tech.' }}">
    <meta property="og:url" content="https://badercodes.com{{ page.url }}">
    <meta property="og:site_name" content="badercodes.com">
    <meta property="og:type" content="website">
    <meta property="og:image" content="https://badercodes.com{{ image if image else '/images/hackathon.jpg' }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }} | badercodes.com">
    <meta name="twitter:description" content="{{ description if description else 'Computer Engineer and Cybersecurity enthusiast writing about CTFs, blue team labs, and tech.' }}">
    <meta name="twitter:image" content="https://badercodes.com{{ image if image else '/images/hackathon.jpg' }}">
  </head>
  <body>
    <nav>
      <a href="/" class="brand">badercodes</a>
      <button
        class="nav-toggle"
        onclick="this.classList.toggle('open'); document.getElementById('nav-links').classList.toggle('open')">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <div class="links" id="nav-links">
        <a href="/">Home</a>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
      </div>
    </nav>
    <main style="flex: 1;">{{ content | safe }}</main>
    <footer>
      <small>&copy; 2026 badercodes — All rights reserved&nbsp;·&nbsp; v{{ version }} &nbsp;·&nbsp; build
      {{ buildHash | truncate(7, true, "") }}</small>
    </footer>
    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/cms-1337/";
            });
          }
        });
      }
    </script>
  </body>
</html>