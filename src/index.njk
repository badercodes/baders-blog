---
layout: base.njk
title: Home
---

<style>
  .hero {
    display: flex;
    align-items: stretch;
    position: relative;
    overflow: hidden;
    background: #f5f7fa;
  }
  .hero-left {
    width: 55%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 2rem 3rem;
    position: relative;
    z-index: 2;
    background: #f5f7fa;
    border-right: 1px solid #e0e8f0;
  }
  .identity {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 1.8rem;
  }
  .avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 2px solid #0a3aaa;
    object-fit: cover;
    object-position: center top;
    flex-shrink: 0;
  }
  .name-block .tag {
    font-family: 'Share Tech Mono', monospace;
    color: #0a3aaa;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }
  .name-block h1 {
    font-family: 'Inter', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #0a1a3a;
    letter-spacing: 0.01em;
  }
  .headline {
    font-family: 'Inter', sans-serif;
    font-size: 2.6rem;
    font-weight: 700;
    color: #0a1a3a;
    line-height: 1.15;
    margin-bottom: 0.8rem;
    letter-spacing: -0.02em;
  }
  .headline span {
    color: #0a3aaa;
  }
  .subtitle {
    font-size: 0.88rem;
    color: #0a3aaa;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 1.8rem;
  }
  .bio {
    color: #4a6080;
    font-size: 1rem;
    line-height: 1.85;
    max-width: 480px;
    margin-bottom: 2.5rem;
    font-weight: 400;
  }
  .btns {
    display: flex;
    gap: 1rem;
  }
  .btn-primary {
    background: #0a1a3a;
    border: 1px solid #0a1a3a;
    color: #ffffff;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    padding: 0.75rem 2rem;
    text-decoration: none;
    text-transform: uppercase;
    display: inline-block;
  }
  .btn-outline {
    background: transparent;
    border: 1px solid #c0d0e0;
    color: #4a6080;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    padding: 0.75rem 2rem;
    text-decoration: none;
    text-transform: uppercase;
    display: inline-block;
  }
  .hero-right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 70%;
    display: block;
    filter: brightness(0.9);
    position: absolute;
    top: 0;
    left: 0;
  }
  .hero-right {
    flex: 1;
    position: relative;
    overflow: hidden;
    min-height: 0;
  }
  .hero-right::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, #f5f7fa 0%, transparent 20%);
    z-index: 1;
  }
  .accent-line {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(to right, #0a3aaa, transparent 60%);
    z-index: 5;
  }
  .latest {
    background: #ffffff;
    border-top: 1px solid #e0e8f0;
    padding: 2.5rem 3rem;
  }
  .latest-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }
  .latest-header h2 {
    font-size: 0.75rem;
    color: #0a1a3a;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .latest-header a {
    font-size: 0.75rem;
    color: #0a3aaa;
    letter-spacing: 0.1em;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 600;
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .post-card {
    border: 1px solid #e0e8f0;
    border-top: 3px solid #0a3aaa;
    padding: 1.2rem 1.4rem;
    background: #f8faff;
    text-decoration: none;
    display: block;
  }
  .post-card .post-tag {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: #0a3aaa;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .post-card .post-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: #0a1a3a;
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }
  .post-card .post-date {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.65rem;
    color: #8a9aaa;
    letter-spacing: 0.1em;
  }
  /* Mobile: hide right panel, left takes full width */
  @media(max-width: 768px) {
    .hero-left {
      width: 100%;
      border-right: none;
      padding: 3rem 1.5rem;
    }
    .hero-right {
      display: none;
    }
    .headline {
      font-size: 1.8rem;
    }
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
<div class="hero">
  <div class="hero-left">
    <div class="identity">
      <img class="avatar" src="/images/profile.jpg" alt="Bader Alsabah">
        <div class="name-block">
          <div class="tag">Computer Engineer · Kuwait</div>
          <h1>Bader Alsabah</h1>
        </div>
      </div>
      <div class="headline">Security-First<br>Engineer &amp;
          <span>CTF Player</span>
        </div>
        <div class="subtitle">Cybersecurity · Networks · Purple Teaming</div>
        <p class="bio">Welcome to my blog! This is where I chronicle my cybersecurity journey by sharing lab walkthroughs from
          platforms like TryHackMe and HackTheBox. I also share my thoughts on emerging tech, AI, automation, and anything else
          that sparks my curiosity.
        </p>
        <div class="btns">
          <a href="/blog" class="btn-primary">Read the Blog</a>
          <a href="/about" class="btn-outline">About Me</a>
        </div>
      </div>
      <div class="hero-right">
        <img src="/images/hackathon.jpg" alt="CTF Competition"></div>
        <div class="accent-line"></div>
      </div>
      <div class="latest">
        <div class="latest-header">
          <h2>Latest Posts</h2>
          <a href="/blog">View all posts →</a>
        </div>
        <div class="posts-grid">
          {% for post in collections.post | reverse | limit(3) %}
            <a href="{{ post.url }}" class="post-card">
              <div class="post-tag">{{ post.data.category | default("General") }}</div>
              <div class="post-title">{{ post.data.title }}</div>
              <div class="post-date">{{ post.date | date }}</div>
            </a>
          {% endfor %}
        </div>
      </div>